{
  "version": "0.1",
  "id": "full-flow",
  "entry": "dev",
  "control": {
    "max_repair_loops": 1,
    "max_acceptance_loops": 1,
    "on_acceptance_failure": "auto-loop"
  },
  "nodes": [
    {
      "id": "dev",
      "type": "worker",
      "provider": "claude-code",
      "profile": "developer",
      "goal": "现在我们在测试异常场景，任务会让你输出一个python类，输出hello-world，但是第一次你应该错误输出，如果被判断为不合格后，你再输出正确的信息"
    },
    {
      "id": "accept",
      "type": "verify",
      "provider": "claude-code",
      "profile": "verifier"
    }
  ],
  "edges": [
    {"from": "dev", "to": "accept", "on": "success"}
  ]
}

