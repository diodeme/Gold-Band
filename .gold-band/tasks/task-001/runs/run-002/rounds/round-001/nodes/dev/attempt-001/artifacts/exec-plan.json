{
  "version": "0.1",
  "commands": [
    {
      "id": "fmt-check",
      "run": "cargo fmt --check",
      "purpose": "确保实现古诗词随机展示网站后的 Rust 代码格式符合项目规范",
      "cwd": ".",
      "timeout_sec": null
    },
    {
      "id": "test",
      "run": "cargo test --quiet",
      "purpose": "验证古诗词随机展示页面相关逻辑与现有功能测试全部通过",
      "cwd": ".",
      "timeout_sec": null
    },
    {
      "id": "build",
      "run": "cargo build --quiet",
      "purpose": "确认项目在加入古诗词随机展示网站功能后仍可成功构建交付",
      "cwd": ".",
      "timeout_sec": null
    }
  ]
}