{
  "version": "0.1",
  "id": "full-flow",
  "entry": "dev",
  "control": {
    "max_repair_loops": 1,
    "max_acceptance_loops": 1,
    "on_acceptance_failure": "auto-loop"
  },
  "nodes": [
    {
      "type": "worker",
      "id": "dev",
      "provider": "claude-code",
      "profile": "developer",
      "goal": "Create an exec plan",
      "primary_artifact": "exec-plan"
    },
    {
      "type": "exec",
      "id": "run-tests",
      "plan_from": "dev"
    },
    {
      "type": "verify",
      "id": "accept",
      "provider": "claude-code",
      "profile": "verifier"
    }
  ],
  "edges": [
    {
      "from": "dev",
      "to": "run-tests",
      "on": "success",
      "session": null
    },
    {
      "from": "run-tests",
      "to": "accept",
      "on": "success",
      "session": null
    }
  ]
}